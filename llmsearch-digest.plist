<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.llmsearch.daily-digest</string>

    <key>ProgramArguments</key>
    <array>
        <string>/Users/stanislavgalchonkov/GitHub/LLMLocalSearch/.venv/bin/python</string>
        <string>/Users/stanislavgalchonkov/GitHub/LLMLocalSearch/src/daily_digest.py</string>
        <string>--lang</string>
        <string>uk</string>
        <string>--post</string>
    </array>

    <!-- Run daily at 08:00 local time -->
    <key>StartCalendarInterval</key>
    <dict>
        <key>Hour</key>
        <integer>8</integer>
        <key>Minute</key>
        <integer>0</integer>
    </dict>

    <key>WorkingDirectory</key>
    <string>/Users/stanislavgalchonkov/GitHub/LLMLocalSearch</string>

    <key>StandardOutPath</key>
    <string>/Users/stanislavgalchonkov/GitHub/LLMLocalSearch/data/digests/launchd.log</string>

    <key>StandardErrorPath</key>
    <string>/Users/stanislavgalchonkov/GitHub/LLMLocalSearch/data/digests/launchd-error.log</string>

    <!-- Run missed job if machine was off at scheduled time -->
    <key>RunAtLoad</key>
    <false/>
</dict>
</plist>
