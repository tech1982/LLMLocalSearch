# ===== TELEGRAM =====
# Get your credentials here: https://my.telegram.org/apps
TG_API_ID=12345678
TG_API_HASH=your_api_hash_here
TG_PHONE=+380507766600

# Channels or groups to index (comma-separated)
# You can use a username or numeric ID
TG_CHANNELS=ITWarsawCommunity

# ===== INSTAGRAM =====
# Instagram account login credentials
INSTA_USERNAME=your_instagram_username
INSTA_PASSWORD=your_instagram_password

# Accounts to index (comma-separated, without @)
# Leave empty to index all followed accounts
INSTA_ACCOUNTS=

# ===== SETTINGS =====
# Embedding model (multilingual-e5-small offers a good balance)
EMBEDDING_MODEL=intfloat/multilingual-e5-large-instruct

# ===== AZURE OPENAI =====
# Answer generation via Azure OpenAI
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-4-1
AZURE_OPENAI_API_VERSION=2025-04-01-preview

# Maximum messages per channel during the first indexing run (0 = unlimited)
MAX_MESSAGES_PER_CHANNEL=40000

# How many days back to fetch on first sync or backfill (0 = unlimited)
MAX_DAYS_BACK=1095

# Flush collected messages to DB every N messages (guards against Ctrl+C data loss)
FLUSH_EVERY=5000
